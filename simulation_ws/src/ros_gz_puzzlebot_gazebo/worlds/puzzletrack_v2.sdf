      <include><name>traffic_light_2</name><pose>1.75 -0.255 0.05 0 0 3.14159</pose><uri>model://traffic_light</uri></include>
    </model>

    <light name='light_source_1' type='spot'>
      <pose>1.6 0.9 2.1 0 0 0</pose>
      <direction>0 0 -1</direction>
      <spot><inner_angle>0.6</inner_angle><outer_angle>3.0</outer_angle><falloff>1.0</falloff></spot>
    </light>

    <include>
      <name>border_box</name>
      <pose>1.68 -0.08 0.001 0 0 0</pose>
      <uri>model://border_box_v2</uri>
    </include>

    <plugin filename="traffic_light_plugin" name="TrafficLightPlugin">
      <traffic_light name="traffic_light"><red>10.0</red><green>7.0</green><yellow>3.0</yellow></traffic_light>
      <traffic_light name="traffic_light_2"><green>7.0</green><yellow>3.0</yellow><red>10.0</red></traffic_light>
    </plugin>

