      <include><name>piece_55</name><pose>0.51 2.55 0 0 0 0</pose><uri>model://puzzletrack_piece_2</uri></include>
    </model>

    <model name="traffic_assets">
      <include><name>go_ahead</name><pose>1.275 -0.3 0.07 1.57 0 -1.57</pose><uri>model://go_ahead</uri></include>
      <include><name>go_ahead_2</name><pose>1.24 0.31 0.07 1.57 0 3.14159</pose><uri>model://go_ahead</uri></include>
      <include><name>max_speed</name><pose>2.31 -0.3 0.07 1.57 0 -1.57</pose><uri>model://max_speed</uri></include> 
      <include><name>max_speed_2</name><pose>4.31 -0.35 0.07 1.57 0 0</pose><uri>model://max_speed</uri></include> 
      <include><name>stop</name><pose>3.84 0.22 0.07 1.57 0 -1.57</pose><uri>model://stop</uri></include>
      <include><name>roadwork</name><pose>2.91 2.3 0.07 1.57 0 1.57</pose><uri>model://roadwork</uri></include>
      <include><name>roadwork_2</name><pose>1.30 -0.75 0.07 1.57 0 3.14159</pose><uri>model://roadwork</uri></include>
      <include><name>roundabout</name><pose>2.8 -2.30 0.07 1.57 0 1.57</pose><uri>model://roundabout</uri></include>
      <include><name>roundabout_2</name><pose>0.28 2.33 0.07 1.57 0 -1.57</pose><uri>model://roundabout</uri></include>
      <include><name>turn_right</name><pose>3.84 -0.22 0.07 1.57 0 -1.57</pose><uri>model://turn_right</uri></include>
      <include><name>turn_left</name><pose>-0.75 0.27 0.07 1.57 0 3.1415</pose><uri>model://turn_left</uri></include>
      <include><name>give_way</name><pose>-1.28 0.27 0.07 1.57 0 3.1415</pose><uri>model://give_way</uri></include>
