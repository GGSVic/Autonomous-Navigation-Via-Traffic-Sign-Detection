      <include><name>piece_13</name><pose>4.08 2.04 0 0 0 1.57</pose><uri>model://puzzletrack_piece_1</uri></include>
      <include><name>piece_14</name><pose>4.08 2.55 0 0 0 0</pose><uri>model://puzzletrack_piece_3</uri></include>

